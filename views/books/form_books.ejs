<main class="container">
    <div class="form-container">

        <h2> <%= typeof livro !== 'undefined' ? 'Editar Livro' : 'Adicionar Novo Livro' %></h2>

        <form action="<%= typeof livro !== 'undefined' ? `/books/edit/${livro.id}` : '/books/add' %>" method="POST" enctype="multipart/form-data">

            <div class="input-group">
                <label for="titulo">Título do Livro:</label>
                <input type="text" id="titulo" name="titulo" required
                       value="<%= typeof livro !== 'undefined' ? livro.titulo : '' %>">
            </div>

            <div class="input-group">
                <label for="paginas">Número de Páginas:</label>
                <input type="number" id="paginas" name="paginas" min="1" required
                       value="<%= typeof livro !== 'undefined' ? livro.paginas : '' %>">
            </div>

            <!-- Image source selector -->
            <div style="margin-bottom: 1.5rem; padding: 1rem; border-radius: 12px; background-color: rgba(7,3,15,.45);">
                <p style="margin-bottom: 0.75rem; font-weight: 600;">Capa do Livro:</p>

                <% if (typeof livro !== 'undefined' && livro.imagem) { %>
                    <div style="margin-bottom: 1rem; padding-bottom: 1rem; border-bottom: 1px solid rgba(168,85,247,.18);">
                        <p style="font-size: 0.85rem; margin-bottom: 6px;">Capa atual salva no banco:</p>
                        <img src="<%= livro.imagem %>" alt="Capa atual" style="height: 110px; border-radius: 8px; object-fit: contain; border: 1px solid rgba(168,85,247,.3); background: #07030f; padding: 4px;">
                        <p style="font-size: 0.8rem; color: #ffb547; margin-top: 6px;">
                            * Para manter esta capa, deixe as opções abaixo vazias.
                        </p>
                    </div>
                <% } %>

                <div style="display: flex; gap: 1.25rem; margin-bottom: 1rem; flex-wrap: wrap;">
                    <label style="display:inline-flex; align-items:center; gap:.4rem; cursor:pointer;">
                        <input type="radio" name="tipo_imagem" value="url" checked onchange="toggleImagemInput()">
                        Usar Link da Internet
                    </label>
                    <label style="display:inline-flex; align-items:center; gap:.4rem; cursor:pointer;">
                        <input type="radio" name="tipo_imagem" value="upload" onchange="toggleImagemInput()">
                        Fazer Upload do PC
                    </label>
                </div>

                <div id="div_url">
                    <input type="url" id="imagem_url" name="imagem_url"
                        value="<%= typeof livro !== 'undefined' && livro.imagem && livro.imagem.startsWith('http') ? livro.imagem : '' %>"
                        placeholder="https://exemplo.com/capa.jpg">
                    <small style="display:block; margin-top:.4rem; font-size:.8rem;">Cole o link direto para a imagem.</small>
                </div>

                <div id="div_upload" style="display: none;">
                    <input type="file" id="imagem_arquivo" name="imagem_upload" accept="image/*">
                    <small style="display:block; margin-top:.4rem; font-size:.8rem;">Selecione uma imagem do seu computador.</small>
                </div>
            </div>

            <button type="submit">
                <%= typeof livro !== 'undefined' ? '💾 Salvar Alterações' : '✨ Adicionar Livro' %>
            </button>
        </form>
    </div>
</main>

<script>
    function toggleImagemInput() {
        const tipo = document.querySelector('input[name="tipo_imagem"]:checked').value;
        document.getElementById('div_url').style.display    = (tipo === 'url')    ? 'block' : 'none';
        document.getElementById('div_upload').style.display = (tipo === 'upload') ? 'block' : 'none';
    }
</script>
