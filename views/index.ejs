<% if (locals.user) { %>
  <div class="dashboard">
    <h2>Você tem <%= livros.length %> livros</h2>

    <% if (livros.length === 0) { %>
      <p>Você ainda não possui livros. <a href="/books/add">Adicionar livros</a></p>
    <% } else { %>

      <div class="livros-grid">
        <% livros.forEach(livro => { %>
          <div class="livro-card">
            <img src="<%= livro.imagem %>" alt="Capa do livro <%= livro.titulo %>">
            <h3><%= livro.titulo %></h3>
            <p>Páginas: <%= livro.paginas %></p>

            <div class="menu-opcoes">
              <button class="btn-pontinhos" onclick="toggleMenu(this)">&#8942;</button>
              <div class="dropdown-menu">
                <a href="/books/edit/<%= livro.id %>">Editar</a>
                <form action="/books/delete/<%= livro.id %>" method="post" onsubmit="return confirm('Tem certeza que deseja deletar este livro? Esta ação não pode ser desfeita.');">
                  <button class="btn-deletar" type="submit">Deletar</button>
                </form>
              </div>
            </div>
          </div>
        <% }) %>
      </div>

    <% } %>
  </div>
<% } else { %>

  <div class="dashboard" style="text-align:center; padding: 3rem 0;">
    <h2 class="texto-formatado">Bem-vindo ao <%= title %></h2>
    <p style="font-size: 1.1rem; max-width: 560px; margin: 0 auto 0.5rem;">Um site que era para ser uma plataforma de e-learning…</p>
    <p style="font-size: 1.1rem; max-width: 560px; margin: 0 auto;">…e virou uma biblioteca virtual.</p>

    <div style="margin-top: 2rem; display:flex; gap:.75rem; justify-content:center; flex-wrap:wrap;">
      <a href="/account/register" class="link-header btn-outline">Criar Conta</a>
      <a href="/account/login" class="link-header btn-outline">Fazer Login</a>
    </div>
  </div>

<% } %>

<script>
    function toggleMenu(botao) {
        const menu = botao.nextElementSibling;
        document.querySelectorAll('.dropdown-menu.mostrar').forEach(m => {
            if (m !== menu) m.classList.remove('mostrar');
        });
        menu.classList.toggle('mostrar');
    }

    document.addEventListener('click', function(event) {
        if (!event.target.closest('.menu-opcoes')) {
            document.querySelectorAll('.dropdown-menu.mostrar').forEach(menu => {
                menu.classList.remove('mostrar');
            });
        }
    });
</script>
