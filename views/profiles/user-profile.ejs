<div class="profile-dashboard">

    <!-- Banner -->
    <div class="profile-banner">
        <div class="profile-banner-inner">
            <div class="profile-avatar" aria-hidden="true">
                <%= (perfil.first_name || perfil.username || '?').charAt(0).toUpperCase() %>
            </div>
            <div class="profile-banner-text">
                <h1><%= perfil.first_name ? (perfil.first_name + ' ' + (perfil.last_name || '')) : perfil.username %></h1>
                <p>@<%= perfil.username %></p>
            </div>
        </div>
    </div>

    <!-- Stats -->
    <div class="perfil-stats">
        <div class="perfil-stat-card">
            <span class="perfil-stat-label">Nome</span>
            <span class="perfil-stat-value"><%= perfil.first_name || '—' %></span>
        </div>
        <div class="perfil-stat-card">
            <span class="perfil-stat-label">Sobrenome</span>
            <span class="perfil-stat-value"><%= perfil.last_name || '—' %></span>
        </div>
        <div class="perfil-stat-card">
            <span class="perfil-stat-label">Usuário</span>
            <span class="perfil-stat-value">@<%= perfil.username %></span>
        </div>
        <div class="perfil-stat-card destaque">
            <span class="perfil-stat-label">Livros publicados</span>
            <span class="perfil-stat-value"><%= totalLivros %></span>
        </div>
    </div>

    <!-- Conteúdo -->
    <div class="profile-content">
        <h2>Sobre <%= perfil.first_name || perfil.username %></h2>
        <p style="color: var(--text-muted); font-size: .98rem; line-height: 1.55;">
            <% if (totalLivros > 0) { %>
                <%= perfil.first_name || perfil.username %> já contribuiu com
                <strong><%= totalLivros %></strong> <%= totalLivros === 1 ? 'livro' : 'livros' %>
                para a comunidade do <%= title || 'EduStream' %>.
            <% } else { %>
                Este usuário ainda não publicou nenhum livro.
            <% } %>
        </p>

        <div class="form-actions" style="justify-content: flex-start;">
            <a href="/profiles/explorer" class="btn-cancel" style="text-decoration:none; display:inline-flex; align-items:center;">
                ← Voltar à biblioteca
            </a>
        </div>
    </div>
</div>

<style>
    .profile-banner-inner {
        position: relative;
        display: flex;
        align-items: center;
        gap: 1.25rem;
    }

    .profile-avatar {
        width: 88px;
        height: 88px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2.2rem;
        font-weight: 700;
        color: #fff;
        background: rgba(255, 255, 255, 0.18);
        border: 2px solid rgba(255, 255, 255, 0.35);
        backdrop-filter: blur(8px);
        box-shadow: 0 10px 30px -10px rgba(0,0,0,.35);
        flex-shrink: 0;
        animation: avatarFloat 4s ease-in-out infinite;
    }

    @keyframes avatarFloat {
        0%, 100% { transform: translateY(0); }
        50%      { transform: translateY(-4px); }
    }

    .profile-banner-text h1 { margin-bottom: .25rem; }
    .profile-banner-text p {
        font-size: 1rem;
        opacity: .9;
        letter-spacing: .02em;
    }

    .perfil-stats {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 1rem;
        margin-bottom: 1.5rem;
        animation: fadeUp .55s ease-out both;
    }

    .perfil-stat-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        padding: 1.1rem 1.2rem;
        backdrop-filter: blur(14px);
        display: flex;
        flex-direction: column;
        gap: .35rem;
        transition: transform .25s ease, box-shadow .25s ease, border-color .25s ease;
    }
    .perfil-stat-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 12px 30px -16px rgba(168, 85, 247, .55);
        border-color: var(--purple-glow);
    }

    .perfil-stat-label {
        font-size: .78rem;
        text-transform: uppercase;
        letter-spacing: .08em;
        color: var(--text-dim);
    }

    .perfil-stat-value {
        font-size: 1.15rem;
        font-weight: 600;
        color: var(--text);
        word-break: break-word;
    }

    .perfil-stat-card.destaque .perfil-stat-value {
        font-size: 1.6rem;
        background: linear-gradient(120deg, var(--purple-light), var(--purple-glow));
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    @media (max-width: 820px) {
        .perfil-stats { grid-template-columns: repeat(2, 1fr); }
    }
    @media (max-width: 480px) {
        .perfil-stats { grid-template-columns: 1fr; }
        .profile-banner-inner { flex-direction: column; text-align: center; }
    }
</style>