<section class="auth-card">
    <h2>Login</h2>

    <form action="/account/login" method="POST">
        <div class="form-group">
            <label>Nome de Usuário ou Email:</label>
            <input type="text" name="email_username" required>
        </div>

        <div class="form-group">
            <label>Senha:</label>
            <input type="password" name="senha" required>
        </div>

        <button type="submit" class="btn-primary">Fazer login</button>
    </form>

    <p style="text-align:center; margin-top: 1.25rem; font-size:.9rem;">
        Ainda não tem conta? <a href="/account/register">Cadastre-se</a>
    </p>
</section>
